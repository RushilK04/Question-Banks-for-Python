def count_word_frequency(sentence):
    words = sentence.split()
    freq = {}

    for word in words:
        word = word.lower()
        if word in freq:
            freq[word] += 1
        else:
            freq[word] = 1

    return freq


sentence = input("Enter a sentence: ")

result = count_word_frequency(sentence)

print("Word Frequencies:")
for word, count in result.items():
    print(word, ":", count)
