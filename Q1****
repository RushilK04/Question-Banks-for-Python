def is_prime(n):
    if n <= 1:
        return False
    for i in range(2, int(n**0.5) + 1):
        if n % i == 0:
            return False
    return True

def remove_primes(lst):
    return list(filter(lambda x: not is_prime(x), lst))

numbers = list(map(int, input().split()))
result = remove_primes(numbers)
print(result)
